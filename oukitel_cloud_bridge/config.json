{
  "name": "Oukitel Cloud Bridge (Experimental)",
  "version": "0.1.0",
  "slug": "oukitel_cloud_bridge",
  "description": "EXPERIMENTAL - Community bridge for Oukitel power stations via Wonderfree/Landbook app (Acceleronix backend). NOT affiliated with Oukitel.",
  "arch": ["aarch64", "amd64", "armv7", "armhf", "i386"],
  "init": false,
  "startup": "services",
  "boot": "manual",
  "host_network": true,
  "options": {
    "wf_email": "",
    "wf_password": "",
    "app": "wonderfree",
    "mqtt_host": "core-mosquitto",
    "mqtt_port": 1883,
    "mqtt_user": "",
    "mqtt_pass": "",
    "ha_base": "oukitel",
    "discovery_prefix": "homeassistant",
    "log_level": "INFO",
    "publish_only_changed": false,
    "dedup_ms": 200,
    "poll_min": 2,
    "poll_max": 20,
    "stale_sec": 60,
    "send_strategy": "auto",
    "observer_only": false,
    "clear_retained": false
  },
  "schema": {
    "wf_email": "str",
    "wf_password": "str",
    "app": "str",
    "mqtt_host": "str",
    "mqtt_port": "int",
    "mqtt_user": "str",
    "mqtt_pass": "str",
    "ha_base": "str",
    "discovery_prefix": "str",
    "log_level": "str",
    "publish_only_changed": "bool",
    "dedup_ms": "int",
    "poll_min": "int",
    "poll_max": "int",
    "stale_sec": "int",
    "send_strategy": "str",
    "observer_only": "bool",
    "clear_retained": "bool"
  }
}
